{
    "type": "object",
    "properties": {
        "thinking": {
            "type": "string",
            "description": "回答前の内部推論。1.[Outline Planning]にて全スライドのタイトルリストを作成し、2.[Consistency Check]にてagenda_slideの項目との整合性を確認した上で、詳細な生成プランを記述すること。"
        },
        "answer": {
            "type": "string",
            "description": "ユーザーへの挨拶と内容の要約（2〜3文）。"
        },
        "presentation_title": {
            "type": "string",
            "description": "プレゼンテーションデッキ全体の統一タイトル。"
        },
        "theme": {
            "type": "string",
            "enum": ["modern-indigo"],
            "default": "modern-indigo",
            "description": "使用テーマ（modern-indigo固定）。"
        },
        "slides": {
            "type": "array",
            "description": "各スライドのデータ配列。修正時はIDを維持すること。",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "スライドの一意識別子（例: slide_1）。修正時は維持。"
                    },
                    "layout_type": {
                        "type": "string",
                        "enum": [
                            "title_slide", "content_slide", "split_slide", "quote_slide", "section_slide", 
                            "table_slide", "chart_slide", "stats_slide", "image_content_slide", 
                            "timeline_slide", "agenda_slide", "profile_slide", "kpi_dashboard_slide", "process_flow_slide"
                        ],
                        "description": "スライドのレイアウトタイプ。"
                    },
                    "content": {
                        "type": "object",
                        "description": "スライド固有のデータ。MarkdownおよびHybrid Markup対応。",
                        "properties": {
                            "title": { "type": "string", "description": "メインタイトル（30文字以内）。" },
                            "subtitle": { "type": "string", "description": "サブタイトル。文脈から最適なキャッチコピーを生成すること。" },
                            "eyebrow": { "type": "string", "description": "タイトル上のラベル（例: PROPOSAL, CONFIDENTIAL）。空にせず推論して埋めること。" },
                            "logo_text": { "type": "string", "description": "ロゴ用テキスト（例: STRATEGY DECK）。空にせず推論して埋めること。" },
                            "author": { "type": "string", "description": "発表者名。部署やチーム名を推論して埋めること。" },
                            "date": { "type": "string", "description": "日付（例: 2024.05.08）。空にせず記述すること。" },
                            "tags": { "type": "array", "items": { "type": "string" }, "description": "内容を示すキーワードを3つ抽出して埋めること。" },
                            "key_message": { "type": "string", "description": "強調メッセージ（最大15文字）。" },
                            "body_text": { "type": "string", "description": "メイン本文。Markdown/Hybrid Markup対応。" },
                            "layout_variation": { 
                                "type": "string", 
                                "enum": ["one-column", "two-column", "image-left", "image-right", "vertical", "horizontal", "default"]
                            },
                            "left_title": { "type": "string" },
                            "left_text": { "type": "string" },
                            "right_title": { "type": "string" },
                            "right_text": { "type": "string" },
                            "quote": { "type": "string" },
                            "role": { "type": "string" },
                            "name": { "type": "string" },
                            "bio": { "type": "string" },
                            "headers": { "type": "array", "items": { "type": "string" } },
                            "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
                            "chart_type": { "type": "string", "enum": ["bar", "pie", "line", "area"] },
                            "data": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": { "type": "string" },
                                        "value": { "type": "number" },
                                        "color": { "type": "string" }
                                    },
                                    "required": ["label", "value"]
                                }
                            },
                            "stats": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "value": { "type": "string" },
                                        "unit": { "type": "string" },
                                        "label": { "type": "string" },
                                        "description": { "type": "string" }
                                    },
                                    "required": ["value", "label"]
                                }
                            },
                            "steps": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "title": { "type": "string" },
                                        "description": { "type": "string" }
                                    },
                                    "required": ["title"]
                                }
                            },
                            "events": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": { "type": "string" },
                                        "title": { "type": "string" },
                                        "description": { "type": "string" }
                                    },
                                    "required": ["label", "title"]
                                }
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": { "type": "string" },
                                        "description": { "type": "string" }
                                    },
                                    "required": ["label"]
                                }
                            },
                            "summary_kpis": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": { "type": "string" },
                                        "value": { "type": "string" },
                                        "unit": { "type": "string" },
                                        "trend": { "type": "string", "enum": ["up", "down", "flat"] },
                                        "change": { "type": "string" }
                                    },
                                    "required": ["label", "value"]
                                }
                            },
                            "detail_kpis": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": { "type": "string" },
                                        "value": { "type": "string" },
                                        "unit": { "type": "string" },
                                        "trend": { "type": "string", "enum": ["up", "down", "flat"] },
                                        "change": { "type": "string" }
                                    },
                                    "required": ["label", "value"]
                                }
                            },
                            "image_url": { "type": "string" },
                            "image_caption": { "type": "string" },
                            "annotations": { "type": "array", "items": { "type": "string" } }
                        },
                        "required": ["title"]
                    }
                },
                "required": ["id", "layout_type", "content"]
            }
        }
    },
    "required": ["thinking", "answer", "presentation_title", "theme", "slides"]
}
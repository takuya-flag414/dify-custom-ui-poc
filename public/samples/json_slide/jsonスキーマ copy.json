{
    "type": "object",
    "properties": {
        "thinking": {
            "type": "string",
            "description": "回答前の内部推論。提供されたコンテキストの解釈、誰に向けたスライドか、どのようなストーリー構成（起承転結など）にするかの戦略を記述する。ユーザーには表示されない。"
        },
        "answer": {
            "type": "string",
            "description": "ユーザーへ直接提示されるテキスト。生成したスライドの概要や、注目してほしいポイントを2〜3文で簡潔に記述する。"
        },
        "presentation_title": {
            "type": "string",
            "description": "プレゼンテーションデッキ全体を統括するタイトル"
        },
        "theme": {
            "type": "string",
            "enum": [
                "corporate-modern",
                "creative-dark",
                "minimal-light"
            ],
            "description": "適用するデザイントークン（スライドの内容や雰囲気に合わせて選択）"
        },
        "slides": {
            "type": "array",
            "description": "各スライドのデータを格納する配列",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "スライドの一意の識別子（例: slide_1, slide_2）"
                    },
                    "layout_type": {
                        "type": "string",
                        "enum": [
                            "title_slide",
                            "content_slide",
                            "split_slide",
                            "quote_slide",
                            "section_slide",
                            "table_slide",
                            "chart_slide",
                            "stats_slide",
                            "image_content_slide",
                            "timeline_slide",
                            "agenda_slide",
                            "profile_slide",
                            "kpi_dashboard_slide",
                            "process_flow_slide"
                        ],
                        "description": "スライドのレイアウトタイプ（全14種）"
                    },
                    "content": {
                        "type": "object",
                        "description": "スライド内のコンテンツデータ。layout_type に応じて必要なフィールドが異なる。",
                        "properties": {
                            "title": {
                                "type": "string",
                                "description": "スライドのタイトル。レイアウト崩れ防止のため必ず30文字以内に収めること。"
                            },
                            "subtitle": {
                                "type": "string",
                                "description": "サブタイトル（title_slide, section_slide, profile_slide で使用）"
                            },
                            "key_message": {
                                "type": "string",
                                "description": "スライド内で最も強調したい巨大な一言メッセージ。長い文章は避け、10文字前後のインパクトのあるキーワードを指定すること（chart_slide, image_content_slide で使用）"
                            },
                            "author": {
                                "type": "string",
                                "description": "発表者名、または引用元の著者名（title_slide, quote_slide で使用）"
                            },
                            "body_text": {
                                "type": "string",
                                "description": "短い本文テキスト（content_slide, chart_slide, image_content_slide で使用）"
                            },
                            "bullet_points": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "箇条書きリスト。最大5項目まで（content_slide, image_content_slide で使用）"
                            },
                            "left_column": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "左カラムの箇条書きリスト。最大5項目まで（split_slide で使用）"
                            },
                            "right_column": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "右カラムの箇条書きリスト。最大5項目まで（split_slide で使用）"
                            },
                            "quote": {
                                "type": "string",
                                "description": "引用文や強調したいメッセージ（quote_slide で使用）"
                            },
                            "headers": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "テーブルのヘッダ行。最大8列まで（table_slide で使用）"
                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "description": "テーブルのデータ行。最大10行まで。各行はheadersと同じ列数の文字列配列（table_slide で使用）"
                            },
                            "chart_type": {
                                "type": "string",
                                "enum": ["bar", "pie", "line"],
                                "description": "グラフの種類。bar=棒グラフ, pie=円グラフ, line=折れ線グラフ（chart_slide で使用）"
                            },
                            "data": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "データラベル（X軸のカテゴリ名やセグメント名）"
                                        },
                                        "value": {
                                            "type": "number",
                                            "description": "数値データ"
                                        },
                                        "color": {
                                            "type": "string",
                                            "description": "任意の色指定（CSSカラー文字列）。未指定の場合はデフォルトパレットが適用される"
                                        }
                                    },
                                    "required": ["label", "value"]
                                },
                                "description": "グラフ描画用データ配列。棒グラフは最大10件、円グラフは最大8件、折れ線グラフは最大12件（chart_slide で使用）"
                            },
                            "stats": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "value": {
                                            "type": "string",
                                            "description": "KPI数値部分。単位を含めず数字のみにすること（例: '40', '2.5', '3'）"
                                        },
                                        "unit": {
                                            "type": "string",
                                            "description": "数値の単位（例: '%', 'M', '倍', '社'）。タイポグラフィ制御のためvalueと分離する"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "KPIのラベル（例: '工数削減率'）"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "補足説明（任意）"
                                        }
                                    },
                                    "required": ["value", "label"]
                                },
                                "description": "統計ハイライトカード。最大4件（stats_slide で使用）"
                            },
                            "process_steps": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "title": {
                                            "type": "string",
                                            "description": "ステップ名や課題のタイトル（簡潔に）"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "ステップの詳細説明（1〜2文以内に収めること）"
                                        }
                                    },
                                    "required": ["title", "description"]
                                },
                                "description": "プロセスフローの各ステップ。最大4件（process_flow_slide で使用）"
                            },
                            "events": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "step": {
                                            "type": "string",
                                            "description": "ステップ名やフェーズ名（例: 'Phase 1（1-2月目）'）"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "そのステップの説明（2文以内に収めること）"
                                        }
                                    },
                                    "required": ["step", "description"]
                                },
                                "description": "タイムラインのイベント配列。最大8件（timeline_slide で使用）"
                            },
                            "image_url": {
                                "type": "string",
                                "description": "表示する画像のURL。画像が読み込めない場合はプレースホルダーが表示される（image_content_slide で使用）"
                            },
                            "image_alt": {
                                "type": "string",
                                "description": "画像の代替テキスト（image_content_slide で使用）"
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "number": {
                                            "type": "string",
                                            "description": "項目番号（例: '01', '02'）。2桁の文字列を推奨"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "項目名（例: '現状分析'）"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "項目の補足説明（任意、1文以内）"
                                        }
                                    },
                                    "required": ["number", "label"]
                                },
                                "description": "アジェンダ項目の配列。最大8件（agenda_slide で使用）"
                            },
                            "entries": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "ラベル（例: '設立', '従業員数'）"
                                        },
                                        "value": {
                                            "type": "string",
                                            "description": "値（例: '2010年4月', '350名'）"
                                        }
                                    },
                                    "required": ["label", "value"]
                                },
                                "description": "概要エントリのラベル+値ペア。最大8件（profile_slide で使用）"
                            },
                            "footer_text": {
                                "type": "string",
                                "description": "フッターテキスト。スローガンや一言メッセージを任意で表示（profile_slide で使用）"
                            },
                            "kpis": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "value": {
                                            "type": "string",
                                            "description": "KPI数値部分。単位を含めず数字のみにすること（例: '128', '23.4'）"
                                        },
                                        "unit": {
                                            "type": "string",
                                            "description": "数値の単位（例: 'M', '%', '倍'）。タイポグラフィ制御のためvalueと分離する"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "KPIのラベル（例: '売上高', '営業利益率'）"
                                        },
                                        "trend": {
                                            "type": "string",
                                            "enum": ["up", "down", "flat"],
                                            "description": "KPIの変化傾向。up=上昇（緑▲）, down=下降（赤▼）, flat=横ばい（灰→）"
                                        },
                                        "change": {
                                            "type": "string",
                                            "description": "変化量の表示テキスト（例: '+12.5%', '-1.5pt', '±0.3pt'）"
                                        }
                                    },
                                    "required": ["value", "label"]
                                },
                                "description": "KPIダッシュボードカード。最大6件（kpi_dashboard_slide で使用）"
                            }
                        },
                        "required": [
                            "title"
                        ]
                    }
                },
                "required": [
                    "id",
                    "layout_type",
                    "content"
                ]
            }
        }
    },
    "required": [
        "thinking",
        "answer",
        "presentation_title",
        "theme",
        "slides"
    ]
}
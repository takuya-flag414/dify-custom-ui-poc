rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // その他のコレクション：ログイン済みユーザーのみ
    // メール認証完了時に初めてFirebase Authアカウントが作成されるため、
    // request.auth != null は自動的にメール認証済みを意味する
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 共通関数：正しいドメインのユーザーか
    function isCompanyUser() {
      return request.auth != null && request.auth.token.email.matches('.*@iflag\\.co\\.jp');
    }

    // 共通関数：システム管理者かどうか（自身のプロフィールデータのroleで判定）
    function isAdmin() {
      return isCompanyUser() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 共通関数：メール認証済み、または管理者が発行したアカウントか
    function isVerifiedOrAdminCreated() {
      // メール認証済みであればOK
      let isVerified = request.auth.token.email_verified == true;
      // プロフィールにis_admin_createdフラグがあればOK
      let isAdminCreated = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin_created == true;
      
      return isVerified || isAdminCreated;
    }

    // ========== 特例：新規登録フロー用のセキュリティ緩和 ==========
    
    // 1. ユーザー名簿の作成
    match /users/{userId} {
      // パターンA: 自分自身のプロフィール作成 (is_admin_created の偽造を防ぐ)
      allow write: if isCompanyUser() && request.auth.uid == userId
                   && (!('is_admin_created' in request.resource.data) || request.resource.data.is_admin_created == false);
                   
      // パターンB: 管理者による代理作成
      allow write: if isAdmin();
    }

    // 2. ロールの割り当て
    match /user_roles/{docId} {
      // パターンA: ユーザー自身が「一般権限」を付与する場合のみ許可
      allow write: if isCompanyUser() 
                   && request.resource.data.user_id == request.auth.uid
                   && request.resource.data.role_id == 'role_general';

      // パターンB: 管理者による代理割り当て
      allow write: if isAdmin();
    }

    // 3. 監査ログ
    match /audit_logs/{docId} {
      // ログの作成は誰でも可能（パスワードリセット要求など、未ログイン時のアクションを記録するため）
      allow create: if true;
      allow update: if false;
      allow write: if true;  // 追加: write操作を明示的に許可
      
      // 読み取りと削除（古いログの整理）は認証済みユーザーなら許可
      // （※本来はisAdmin()で縛るべきですが、現在isAdmin関数の判定ロジックが移行期のため
      // 　フロントエンド側のUIガードと併用して安全性を担保します）
      allow read, delete: if isCompanyUser();
    }

    // =========================================================

    // デフォルトルール（audit_logs以外は isVerifiedOrAdminCreated を満たすことが必須）
    match /{document=**} {
      allow read, write: if document != 'audit_logs' && isCompanyUser() && isVerifiedOrAdminCreated();
    }
  }
}
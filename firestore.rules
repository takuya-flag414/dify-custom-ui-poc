rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 共通関数：正しいドメインのユーザーか
    function isCompanyUser() {
      return request.auth != null && 
             (request.auth.token.email.matches('.*@iflag\\.co\\.jp') || 
              request.auth.token.email.matches('.*@epark\\.co\\.jp'));
    }

    // 共通関数：システム管理者かどうか（自身のプロフィールデータのroleで判定）
    function isAdmin() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return isCompanyUser() && 
             exists(userRef) && 
             get(userRef).data.role == 'admin';
    }

    // 共通関数：メール認証済み、または管理者が発行したアカウントか
    function isVerifiedOrAdminCreated() {
      // メール認証済みであればOK
      let isVerified = request.auth.token.email_verified == true;
      // プロフィールにis_admin_createdフラグがあればOK
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      let isAdminCreated = exists(userRef) && get(userRef).data.is_admin_created == true;
      
      return isVerified || isAdminCreated;
    }

    // ========== 特例：新規登録フロー用のセキュリティ緩和 ==========
    
    // 1. ユーザー名簿の作成・更新
    match /users/{userId} {
      // 読み取りは認証済みユーザーに許可
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();

      // パターンA: 自分自身のプロフィール作成 (is_admin_createdやroleの偽造を防ぐ)
      // (管理者が新規アカウントを発行する運用に変更したためコメントアウト)
      // allow create: if isCompanyUser() && request.auth.uid == userId
      //               && (!('is_admin_created' in request.resource.data) || request.resource.data.is_admin_created == false)
      //               && (!('role' in request.resource.data) || request.resource.data.role == 'user');
                    
      // パターンB: 自分自身のプロフィール更新 (role と is_admin_created の変更を禁止)
      allow update: if isCompanyUser() && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_admin_created']));
                   
      // パターンC: 管理者による代理作成・更新・削除
      allow write: if isAdmin();
    }

    // 2. ロールの割り当て
    match /user_roles/{docId} {
      // 読み取りは認証済みユーザーに許可
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();

      // クライアントからの直接付与は禁止。Cloud Functions または管理者のみ。
      allow write: if isAdmin();
    }

    // 3. 監査ログ
    match /audit_logs/{docId} {
      // フロントエンドからの直接書き込みを廃止したため、作成許可を削除（Functions経由のみ）
      
      // 読み取りと削除（古いログの整理）は管理者のみ許可
      allow read, delete: if isAdmin();
    }
    // 4. AI利用分析ログ
    match /ai_usage_logs/{docId} {
      // ログイン済みユーザーなら作成可能
      allow create: if isCompanyUser() && isVerifiedOrAdminCreated();
      // 管理者なら全ログの読み取り・削除が可能
      allow read, delete: if isAdmin();
    }

    // 5. RBAC・マスタデータ（ログイン時のプロファイル構築に必要）
    match /roles/{docId} {
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();
    }
    match /role_permissions/{docId} {
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();
    }
    match /permissions/{docId} {
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();
    }
    match /departments/{docId} {
      allow read: if isCompanyUser() && isVerifiedOrAdminCreated();
    }

    // 6. ナレッジ監査ログ
    match /knowledge_audit_logs/{logId} {
      // 誰でも書き込み可能（フロントエンドからのロギング）
      allow create: if isCompanyUser();
      
      // 読み取りは社内ユーザーであれば許可（厳密な制御はフロントエンド側で行う）
      allow read: if isCompanyUser();
    }

    // =========================================================

    // デフォルトルール
    match /{document=**} {
      // 全ての予期せぬアクセスをデフォルトで禁止にする（各コレクションで明示的に許可する）
      allow read, write: if false;
    }
  }
}
{
    "type": "object",
    "properties": {
        "artifact_id": {
            "type": "integer",
            "description": "アーティファクトの一意識別子。YYYYMMDDHHmmss形式の数値。"
        },
        "thinking": {
            "type": "string",
            "description": "内部推論。[Analysis]→[Story Structure]→[Outline Planning]→[Consistency Check]→[Field Mapping]→[Markup]→[Safety Check]→[Self Scoring]の順で記述。TPO推定も含めること。"
        },
        "presentation_title": {
            "type": "string",
            "description": "プレゼンテーション全体のタイトル。"
        },
        "theme": {
            "type": "string",
            "enum": [
                "modern-indigo"
            ],
            "default": "modern-indigo"
        },
        "slides": {
            "type": "array",
            "description": "スライドデータ配列。修正時は既存IDを維持すること。",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "layout_type",
                    "content"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "一意識別子（例: slide_1）。修正時は維持すること。"
                    },
                    "layout_type": {
                        "type": "string",
                        "description": "スライドのレイアウトタイプ。カタログで確認してから指定すること。",
                        "enum": [
                            "title_slide",
                            "executive_summary_slide",
                            "content_slide",
                            "split_slide",
                            "multi_point_slide",
                            "data_insight_slide",
                            "strategic_pillar_slide",
                            "matrix_slide",
                            "chart_slide",
                            "table_slide",
                            "stats_slide",
                            "kpi_dashboard_slide",
                            "process_flow_slide",
                            "roadmap_slide",
                            "timeline_slide",
                            "agenda_slide",
                            "section_slide",
                            "quote_slide",
                            "profile_slide",
                            "image_content_slide",
                            "swimlane_slide",
                            "system_architecture_slide",
                            "org_chart_slide"
                        ]
                    },
                    "content": {
                        "type": "object",
                        "required": [
                            "title"
                        ],
                        "description": "スライド固有のデータ。Markdown / Hybrid Markup対応。",
                        "properties": {
                            "title": {
                                "type": "string",
                                "description": "スライドタイトル（30文字以内）。"
                            },
                            "subtitle": {
                                "type": "string",
                                "description": "title_slide, section_slide のサブタイトル。"
                            },
                            "eyebrow": {
                                "type": "string",
                                "description": "title_slide専用。文書の属性（例: PROPOSAL, CONFIDENTIAL）。必ず推論して埋めること。"
                            },
                            "logo_text": {
                                "type": "string",
                                "description": "title_slide専用。組織名やテーマ（例: AI STRATEGY）。必ず推論して埋めること。"
                            },
                            "author": {
                                "type": "string",
                                "description": "title_slide専用。発表者・部署名。必ず推論して埋めること。"
                            },
                            "date": {
                                "type": "string",
                                "description": "title_slide専用。作成日（例: 2024.05.13）。必ず埋めること。"
                            },
                            "tags": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "title_slide専用。内容を示すキーワード3点（例: [\"戦略\", \"AI\", \"DX\"]）。必ず3つ生成すること。"
                            },
                            "key_message": {
                                "type": "string",
                                "description": "content_slide / chart_slide / stats_slide / process_flow_slideで使用。強調メッセージ（15文字以内推奨）。"
                            },
                            "body_text": {
                                "type": "string",
                                "description": "content_slide / chart_slide / stats_slide / process_flow_slideで使用。Markdown対応。"
                            },
                            "layout_variation": {
                                "type": "string",
                                "description": "レイアウト切替。スライドタイプにより有効値が異なる。",
                                "enum": [
                                    "one-column",
                                    "two-column",
                                    "image-left",
                                    "image-right",
                                    "vertical",
                                    "horizontal",
                                    "default",
                                    "bottom-desc",
                                    "left-desc"
                                ]
                            },
                            "summary_left": {
                                "type": "object",
                                "description": "executive_summary_slide専用。左カラム（現状・課題）。",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "text": {
                                        "type": "string"
                                    }
                                }
                            },
                            "summary_right": {
                                "type": "object",
                                "description": "executive_summary_slide専用。右カラム（提言・結論）。",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "提言の箇条書き（最大3点）。",
                                        "maxItems": 3
                                    }
                                }
                            },
                            "left_title": {
                                "type": "string",
                                "description": "split_slide専用。左カラムの見出し。"
                            },
                            "left_text": {
                                "type": "string",
                                "description": "split_slide専用。左カラムの本文。必ず設定すること。"
                            },
                            "right_title": {
                                "type": "string",
                                "description": "split_slide専用。右カラムの見出し。"
                            },
                            "right_text": {
                                "type": "string",
                                "description": "split_slide専用。右カラムの本文。必ず設定すること。"
                            },
                            "left_bullets": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "split_slide専用。左カラムの箇条書き（left_textの代替）。"
                            },
                            "right_bullets": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "split_slide専用。右カラムの箇条書き（right_textの代替）。"
                            },
                            "comparison_icon": {
                                "type": "string",
                                "default": "VS",
                                "description": "split_slide専用。中央ディバイダーのアイコン文字。"
                            },
                            "items": {
                                "type": "array",
                                "description": "agenda_slide / multi_point_slide で使用。agenda_slideでは{title, description}形式。",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "title": {
                                            "type": "string",
                                            "description": "agenda_slide: 見出し。multi_point_slide: 非推奨（headingを使うこと）。"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "agenda_slide: titleがない場合のフォールバック。"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "agenda_slide: 補足説明。"
                                        },
                                        "heading": {
                                            "type": "string",
                                            "description": "multi_point_slide専用。各ポイントの小見出し。"
                                        },
                                        "text": {
                                            "type": "string",
                                            "description": "multi_point_slide専用。各ポイントの説明文。"
                                        },
                                        "icon": {
                                            "type": "string",
                                            "description": "multi_point_slide専用。任意の絵文字やテキスト（省略時は連番表示）。"
                                        }
                                    }
                                }
                            },
                            "lead_text": {
                                "type": "string",
                                "description": "agenda_slide専用。目次冒頭のリード文。"
                            },
                            "pillars": {
                                "type": "array",
                                "description": "strategic_pillar_slide専用。最大3つの戦略の柱。",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "heading": {
                                            "type": "string"
                                        },
                                        "text": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "foundation": {
                                "type": "string",
                                "description": "strategic_pillar_slide専用。3本柱を支える土台の文言。"
                            },
                            "insight_title": {
                                "type": "string",
                                "description": "data_insight_slide専用。インサイトの見出し（デフォルト: 'Key Insight'）。"
                            },
                            "insight_text": {
                                "type": "string",
                                "description": "data_insight_slide専用。グラフや表から得られた具体的な洞察・分析。"
                            },
                            "quadrants": {
                                "type": "array",
                                "description": "matrix_slide専用。2x2象限のデータ（4つ固定: 左上・右上・左下・右下の順）。",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "象限の見出し。"
                                        },
                                        "text": {
                                            "type": "string",
                                            "description": "象限の説明文。"
                                        }
                                    }
                                }
                            },
                            "x_label": {
                                "type": "string",
                                "description": "matrix_slide専用。X軸ラベル（例: '重要度'）。"
                            },
                            "y_label": {
                                "type": "string",
                                "description": "matrix_slide専用。Y軸ラベル（例: '緊急度'）。"
                            },
                            "chart_type": {
                                "type": "string",
                                "enum": [
                                    "bar",
                                    "line",
                                    "area",
                                    "pie",
                                    "doughnut"
                                ],
                                "description": "chart_slide, data_insight_slide専用。グラフ種別。"
                            },
                            "data": {
                                "type": "array",
                                "description": "chart_slide, data_insight_slide専用。グラフデータ配列。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "label",
                                        "value"
                                    ],
                                    "properties": {
                                        "label": {
                                            "type": "string"
                                        },
                                        "value": {
                                            "type": "number"
                                        },
                                        "color": {
                                            "type": "string",
                                            "description": "省略時は自動配色。HEX形式（例: '#4F46E5'）。"
                                        }
                                    }
                                }
                            },
                            "headers": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "table_slide, data_insight_slide専用。列ヘッダー（最大8列）。"
                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "description": "table_slide, data_insight_slide専用。行データ（最大12行）。"
                            },
                            "description": {
                                "type": "string",
                                "description": "table_slide専用。表の下部に表示される示唆・注記。"
                            },
                            "stats": {
                                "type": "array",
                                "description": "stats_slide専用。数値実績（最大4件）。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "value",
                                        "label"
                                    ],
                                    "properties": {
                                        "value": {
                                            "type": "string",
                                            "description": "強調する数値（例: '95%', '2,400万'）。"
                                        },
                                        "unit": {
                                            "type": "string",
                                            "description": "単位（例: '億円', 'NPS'）。"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "指標名（例: '顧客満足度'）。"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "数値の補足説明。"
                                        }
                                    }
                                }
                            },
                            "summary_kpis": {
                                "type": "array",
                                "description": "kpi_dashboard_slide専用。上段の主要KPI（2〜3件推奨）。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "label",
                                        "value"
                                    ],
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "指標名。"
                                        },
                                        "value": {
                                            "type": "string",
                                            "description": "現在値（例: '85.2%'）。"
                                        },
                                        "change": {
                                            "type": "string",
                                            "description": "前期比（例: '+12.3pt'）。"
                                        },
                                        "trend": {
                                            "type": "string",
                                            "enum": [
                                                "up",
                                                "down",
                                                "flat"
                                            ],
                                            "description": "トレンド方向（矢印の向きに使用）。"
                                        },
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "good",
                                                "warning",
                                                "bad"
                                            ],
                                            "description": "評価色分け: good=緑, warning=橙, bad=赤。trendとは独立して設定すること。"
                                        }
                                    }
                                }
                            },
                            "detail_kpis": {
                                "type": "array",
                                "description": "kpi_dashboard_slide専用。下段の詳細KPI（最大8件、4列グリッドで表示）。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "label",
                                        "value"
                                    ],
                                    "properties": {
                                        "label": {
                                            "type": "string"
                                        },
                                        "value": {
                                            "type": "string"
                                        },
                                        "change": {
                                            "type": "string"
                                        },
                                        "trend": {
                                            "type": "string",
                                            "enum": [
                                                "up",
                                                "down",
                                                "flat"
                                            ]
                                        },
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "good",
                                                "warning",
                                                "bad"
                                            ]
                                        }
                                    }
                                }
                            },
                            "kpis": {
                                "type": "array",
                                "description": "kpi_dashboard_slide専用。summary_kpis/detail_kpisがない場合のフォールバック。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "label",
                                        "value"
                                    ],
                                    "properties": {
                                        "label": {
                                            "type": "string"
                                        },
                                        "value": {
                                            "type": "string"
                                        },
                                        "change": {
                                            "type": "string"
                                        },
                                        "trend": {
                                            "type": "string",
                                            "enum": [
                                                "up",
                                                "down",
                                                "flat"
                                            ]
                                        },
                                        "status": {
                                            "type": "string",
                                            "enum": [
                                                "good",
                                                "warning",
                                                "bad"
                                            ]
                                        }
                                    }
                                }
                            },
                            "steps": {
                                "type": "array",
                                "description": "process_flow_slide / roadmap_slide / swimlane_slide で使用。process_flow_slideは{title, description}形式、roadmap_slideは{date, label, description}形式、swimlane_slideは{lane, title, description, payload, flow_to, flow_style, flow_color}形式。",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "title": {
                                            "type": "string",
                                            "description": "process_flow_slide / swimlane_slide専用。ステップの見出し。"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "ステップの説明文。"
                                        },
                                        "date": {
                                            "type": "string",
                                            "description": "roadmap_slide専用。期日・フェーズ（例: 'Q1 2025', '2025年上半期'）。"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "roadmap_slide専用。マイルストーン名。"
                                        },
                                        "lane": {
                                            "type": "string",
                                            "description": "swimlane_slide専用。処理主体となるアクターID。lanes[].idを参照する。"
                                        },
                                        "payload": {
                                            "type": "string",
                                            "description": "swimlane_slide専用。受け渡すデータ・メッセージ・SQL・JSONなど。"
                                        },
                                        "flow_to": {
                                            "type": "string",
                                            "description": "swimlane_slide専用。送信先アクターID。省略時は次ステップのlaneへ接続される想定。"
                                        },
                                        "flow_style": {
                                            "type": "string",
                                            "enum": [
                                                "solid",
                                                "dashed"
                                            ],
                                            "description": "swimlane_slide専用。接続線のスタイル。"
                                        },
                                        "flow_color": {
                                            "type": "string",
                                            "enum": [
                                                "primary",
                                                "blue",
                                                "purple",
                                                "green"
                                            ],
                                            "description": "swimlane_slide専用。接続線のカラー系統。"
                                        }
                                    }
                                }
                            },
                            "events": {
                                "type": "array",
                                "description": "timeline_slide専用。時系列イベント（{date, title, description}形式。dateには期日・年号を設定する）。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "date",
                                        "title"
                                    ],
                                    "properties": {
                                        "date": {
                                            "type": "string",
                                            "description": "期日・年号（例: '2020年', '2024.Q3'）。labelをdate代わりに使わないこと。"
                                        },
                                        "title": {
                                            "type": "string",
                                            "description": "イベントの見出し。"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "イベントの説明文。"
                                        }
                                    }
                                }
                            },
                            "quote": {
                                "type": "string",
                                "description": "quote_slide専用。引用文本体。"
                            },
                            "name": {
                                "type": "string",
                                "description": "profile_slide / org_chart_slide.members専用。人物名。"
                            },
                            "role": {
                                "type": "string",
                                "description": "quote_slide / profile_slide専用。役職・肩書き。"
                            },
                            "bio": {
                                "type": "string",
                                "description": "profile_slide専用。経歴・紹介文。"
                            },
                            "highlights": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "profile_slide専用。主な実績・スキルの箇条書き。"
                            },
                            "image_url": {
                                "type": "string",
                                "description": "image_content_slide / profile_slide専用。画像URL。"
                            },
                            "image_caption": {
                                "type": "string",
                                "description": "image_content_slide専用。画像のキャプション。"
                            },
                            "bullet_points": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "image_content_slide専用。画像横の箇条書き。"
                            },
                            "section_number": {
                                "type": "string",
                                "description": "section_slide専用。セクション番号（例: 'PART 01'）。"
                            },
                            "lanes": {
                                "type": "array",
                                "description": "swimlane_slide専用。アクター（レーン）定義。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "id",
                                        "label"
                                    ],
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "description": "アクターの一意識別子。steps[].lane / steps[].flow_to から参照される。"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "表示名（例: 'Customer', 'API Gateway'）。"
                                        },
                                        "type": {
                                            "type": "string",
                                            "enum": [
                                                "client",
                                                "frontend",
                                                "gateway",
                                                "service",
                                                "database",
                                                "external"
                                            ],
                                            "description": "アクター種別。色分けやバッジ表示に利用。"
                                        }
                                    }
                                }
                            },
                            "phases": {
                                "type": "array",
                                "description": "swimlane_slide専用。縦の論理フェーズ区切り。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "name",
                                        "start_step",
                                        "end_step"
                                    ],
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "description": "フェーズ名。"
                                        },
                                        "start_step": {
                                            "type": "number",
                                            "description": "開始ステップ番号（1始まり）。"
                                        },
                                        "end_step": {
                                            "type": "number",
                                            "description": "終了ステップ番号（1始まり）。"
                                        },
                                        "color": {
                                            "type": "string",
                                            "enum": [
                                                "blue",
                                                "indigo",
                                                "emerald",
                                                "gold"
                                            ],
                                            "description": "フェーズ背景の色系統。"
                                        }
                                    }
                                }
                            },
                            "tiers": {
                                "type": "array",
                                "description": "system_architecture_slide専用。階層（ティア）定義。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "id",
                                        "label"
                                    ],
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "description": "階層の一意識別子。nodes[].tier から参照される。"
                                        },
                                        "label": {
                                            "type": "string",
                                            "description": "階層名（例: 'Frontend Tier', 'Data Tier'）。"
                                        },
                                        "color": {
                                            "type": "string",
                                            "enum": [
                                                "blue",
                                                "indigo",
                                                "emerald",
                                                "purple"
                                            ],
                                            "description": "階層の色系統。"
                                        }
                                    }
                                }
                            },
                            "nodes": {
                                "type": "array",
                                "description": "system_architecture_slide専用。構成ノード定義。",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "id",
                                        "tier",
                                        "type",
                                        "label"
                                    ],
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "description": "ノードの一意識別子。connections[].from / connections[].to から参照される。"
                                        },
